/* components/item-card/item-card.wxss */
.card {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 20rpx;
  gap: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  border-left: 8rpx solid transparent;
}

.bg-normal  { border-left-color: #4CAF82; }
.bg-near    { border-left-color: #FF9800; }
.bg-expired { border-left-color: #F44336; }

.card-image-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.card-image { width: 96rpx; height: 96rpx; }

.card-image-placeholder {
  width: 96rpx;
  height: 96rpx;
  background: #F0F0F0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-icon { font-size: 48rpx; }

.card-content { flex: 1; min-width: 0; }

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.card-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-meta {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.card-category {
  font-size: 22rpx;
  color: #FFFFFF;
  background: #AAAAAA;
  border-radius: 6rpx;
  padding: 2rpx 12rpx;
}

.card-date {
  font-size: 24rpx;
  color: #999;
}

.card-arrow {
  color: #CCCCCC;
  font-size: 40rpx;
  flex-shrink: 0;
}
