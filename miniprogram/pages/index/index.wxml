<!-- pages/index/index.wxml -->
<view class="container">
  <!-- 临期提示横幅 -->
  <view wx:if="{{nearCount > 0}}" class="alert-banner">
    <text class="alert-icon">⚠️</text>
    <text>有 {{nearCount}} 件物品临期或已过期，请及时处理</text>
  </view>

  <!-- 状态筛选 Tab -->
  <view class="filter-tabs">
    <view
      class="filter-tab {{activeFilter === 'all' ? 'active' : ''}}"
      data-filter="all"
      bindtap="onFilterTap"
    >全部</view>
    <view
      class="filter-tab {{activeFilter === 'near' ? 'active' : ''}}"
      data-filter="near"
      bindtap="onFilterTap"
    >临期</view>
    <view
      class="filter-tab {{activeFilter === 'expired' ? 'active' : ''}}"
      data-filter="expired"
      bindtap="onFilterTap"
    >已过期</view>
  </view>

  <!-- 分类筛选 -->
  <scroll-view class="category-scroll" scroll-x>
    <view class="category-tabs">
      <view
        wx:for="{{categoryList}}"
        wx:key="*this"
        class="category-tab {{activeCategory === item ? 'active' : ''}}"
        data-category="{{item}}"
        bindtap="onCategoryTap"
      >{{item}}</view>
    </view>
  </scroll-view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="empty-tip">加载中...</view>

  <!-- 空状态 -->
  <view wx:elif="{{filteredItems.length === 0}}" class="empty-tip">
    <image class="empty-img" src="/assets/icons/empty.png" mode="aspectFit"/>
    <text>暂无物品，点击 + 添加</text>
  </view>

  <!-- 物品列表 -->
  <view wx:else class="item-list">
    <item-card
      wx:for="{{filteredItems}}"
      wx:key="_id"
      item="{{item}}"
      bindtap="onItemTap"
      data-id="{{item._id}}"
    />
  </view>

  <!-- 添加按钮 -->
  <view class="fab" bindtap="onAddTap">
    <text class="fab-icon">+</text>
  </view>
</view>
