/* pages/index/index.wxss */
.container {
  padding-bottom: 160rpx;
  min-height: 100vh;
}

.alert-banner {
  background-color: #FFF3E0;
  padding: 20rpx 32rpx;
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #FF6D00;
  border-bottom: 1rpx solid #FFE0B2;
}

.alert-icon {
  margin-right: 12rpx;
  font-size: 30rpx;
}

.filter-tabs {
  display: flex;
  background-color: #FFFFFF;
  padding: 0 32rpx;
  border-bottom: 1rpx solid #EEEEEE;
}

.filter-tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #999999;
  border-bottom: 4rpx solid transparent;
}

.filter-tab.active {
  color: #4CAF82;
  border-bottom-color: #4CAF82;
  font-weight: 500;
}

.item-list {
  padding: 24rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 160rpx;
  color: #BBBBBB;
  font-size: 28rpx;
  gap: 24rpx;
}

.empty-img {
  width: 200rpx;
  height: 200rpx;
  opacity: 0.4;
}

.fab {
  position: fixed;
  right: 48rpx;
  bottom: 120rpx;
  width: 100rpx;
  height: 100rpx;
  background-color: #4CAF82;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(76, 175, 130, 0.4);
}

.fab-icon {
  color: #FFFFFF;
  font-size: 56rpx;
  line-height: 1;
  margin-top: -4rpx;
}
