/* pages/detail/detail.wxss */
.container { padding-bottom: 120rpx; }

.image-section { width: 100%; height: 400rpx; }
.item-image { width: 100%; height: 400rpx; }

.status-card {
  padding: 40rpx 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.status-name { font-size: 40rpx; font-weight: 600; color: #333; }

.info-section {
  background: #FFFFFF;
  margin-top: 20rpx;
  padding: 0 32rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}
.info-row:last-child { border-bottom: none; }

.info-label { font-size: 28rpx; color: #999; flex-shrink: 0; }
.info-value { font-size: 28rpx; color: #333; text-align: right; flex: 1; margin-left: 32rpx; word-break: break-all; }

.action-area { padding: 32rpx; display: flex; flex-direction: column; gap: 20rpx; }

.btn-cancel {
  width: 100%; background-color: #F5F5F5; color: #666;
  border-radius: 12rpx; border: none;
  height: 96rpx; line-height: 96rpx; font-size: 34rpx;
}

/* 复用 add 页样式 */
.section { background: #FFF; margin-top: 20rpx; padding: 32rpx; }
.section-title { font-size: 24rpx; color: #999; margin-bottom: 24rpx; }
.image-upload { display: flex; justify-content: center; }
.image-placeholder { width: 200rpx; height: 200rpx; background: #F5F5F5; border-radius: 16rpx; border: 2rpx dashed #DDD; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 12rpx; }
.upload-icon { font-size: 56rpx; }
.upload-text { font-size: 24rpx; color: #AAA; }
.image-preview { position: relative; width: 200rpx; height: 200rpx; }
.preview-img { width: 200rpx; height: 200rpx; border-radius: 16rpx; }
.image-remove { position: absolute; top: -16rpx; right: -16rpx; width: 44rpx; height: 44rpx; background: rgba(0,0,0,0.5); border-radius: 22rpx; color: #FFF; font-size: 32rpx; display: flex; align-items: center; justify-content: center; text-align: center; line-height: 44rpx; }
.form-group { padding: 20rpx 0; border-bottom: 1rpx solid #F5F5F5; }
.form-group:last-child { border-bottom: none; }
.label { font-size: 28rpx; color: #333; display: block; margin-bottom: 12rpx; }
.required { color: #F44336; }
.input { width: 100%; height: 72rpx; background: #F8F8F8; border-radius: 8rpx; padding: 0 20rpx; font-size: 28rpx; color: #333; }
.picker-value { display: flex; justify-content: space-between; align-items: center; height: 72rpx; background: #F8F8F8; border-radius: 8rpx; padding: 0 20rpx; font-size: 28rpx; color: #333; }
.arrow { color: #CCC; font-size: 36rpx; }
.textarea { width: 100%; min-height: 160rpx; background: #F8F8F8; border-radius: 8rpx; padding: 20rpx; font-size: 28rpx; color: #333; line-height: 1.6; }
