/* pages/profile/profile.wxss */
.container { padding: 0; }

.user-card {
  background: #4CAF82;
  padding: 80rpx 40rpx 60rpx;
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  border: 4rpx solid rgba(255,255,255,0.6);
}

.avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: rgba(255,255,255,0.2);
  font-size: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  line-height: 120rpx;
}

.user-info { display: flex; flex-direction: column; gap: 12rpx; }
.nickname { font-size: 36rpx; font-weight: 600; color: #FFFFFF; }
.sub-text { font-size: 24rpx; color: rgba(255,255,255,0.8); }

.login-btn {
  background: rgba(255,255,255,0.25);
  color: #FFFFFF;
  border: none;
  border-radius: 8rpx;
  font-size: 28rpx;
  padding: 10rpx 28rpx;
  height: auto;
  line-height: 1.5;
}

.section {
  background: #FFFFFF;
  margin-top: 24rpx;
  padding: 0 32rpx;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 36rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
  font-size: 30rpx;
  color: #333;
}

.menu-item:last-child { border-bottom: none; }
.menu-value { color: #999; font-size: 28rpx; }
.arrow { color: #CCC; font-size: 36rpx; }
