/* pages/add/add.wxss */
.container {
  padding: 24rpx 0 120rpx;
}

.section {
  background: #FFFFFF;
  margin-bottom: 20rpx;
  padding: 32rpx;
}

.section-title {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 24rpx;
  font-weight: 500;
}

.image-upload {
  display: flex;
  justify-content: center;
}

.image-placeholder {
  width: 200rpx;
  height: 200rpx;
  background: #F5F5F5;
  border-radius: 16rpx;
  border: 2rpx dashed #DDDDDD;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.upload-icon { font-size: 56rpx; }
.upload-text { font-size: 24rpx; color: #AAAAAA; }

.image-preview {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.preview-img {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
}

.image-remove {
  position: absolute;
  top: -16rpx;
  right: -16rpx;
  width: 44rpx;
  height: 44rpx;
  background: rgba(0,0,0,0.5);
  border-radius: 22rpx;
  color: #FFFFFF;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 44rpx;
  text-align: center;
}

.form-group {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.form-group:last-child { border-bottom: none; }

.label {
  font-size: 28rpx;
  color: #333333;
  display: block;
  margin-bottom: 12rpx;
}

.required { color: #F44336; }

.input {
  width: 100%;
  height: 72rpx;
  background: #F8F8F8;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333333;
}

.picker-value {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 72rpx;
  background: #F8F8F8;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333333;
}

.picker-value.placeholder { color: #AAAAAA; }
.arrow { color: #CCCCCC; font-size: 36rpx; }

.textarea {
  width: 100%;
  min-height: 160rpx;
  background: #F8F8F8;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
}

.submit-area {
  padding: 32rpx;
}

.btn-primary {
  width: 100%;
  background-color: #4CAF82;
  color: #FFFFFF;
  border-radius: 12rpx;
  border: none;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 34rpx;
  font-weight: 500;
}
